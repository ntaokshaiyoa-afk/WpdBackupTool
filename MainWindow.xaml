<Window x:Class="WpdBackupTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iPhone WPD Backup"
        Height="500" Width="750">
    <DockPanel Margin="10">

        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,10">
            <Button Content="保存先選択" Width="120" Click="SelectFolder_Click"/>
            <TextBox Name="PathBox" Margin="10,0,0,0" Width="450"/>
            <Button Content="バックアップ開始" Margin="10,0,0,0" Click="Start_Click"/>
        </StackPanel>

        <TextBox Name="LogBox"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"/>
    </DockPanel>
</Window>
